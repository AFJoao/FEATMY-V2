rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPersonal() {
      return isAuth() && getUserData().userType == 'personal';
    }

    function hasActiveSubscription(personalId) {
      return exists(/databases/$(database)/documents/subscriptions/$(personalId)) &&
        get(/databases/$(database)/documents/subscriptions/$(personalId)).data.status
          in ['active', 'grace_period'];
    }

    function isWithinStudentLimit(personalId) {
      let subDoc       = get(/databases/$(database)/documents/subscriptions/$(personalId));
      let maxStudents  = subDoc.data.maxStudents;
      let userDoc      = get(/databases/$(database)/documents/users/$(personalId));
      let currentCount = ('studentCount' in userDoc.data && userDoc.data.studentCount != null)
        ? userDoc.data.studentCount
        : (('students' in userDoc.data && userDoc.data.students != null)
           ? userDoc.data.students.size()
           : 0);
      return exists(/databases/$(database)/documents/subscriptions/$(personalId)) &&
        currentCount < maxStudents;
    }

    function isOwnStudentDoc() {
      return isAuth()
        && resource.data.userType == 'student'
        && resource.data.authUid == request.auth.uid;
    }

    function isMyStudentDoc() {
      return isPersonal() && resource.data.personalId == request.auth.uid;
    }

    // ── USERS ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Leitura de documento único
      allow get: if isUser(userId)
        || (resource.data.status == 'pending'
            && resource.data.userType == 'student'
            && isAuth()
            && resource.data.personalId == request.auth.uid)
        || (isAuth()
            && isPersonal()
            && resource.data.userType == 'student'
            && resource.data.personalId == request.auth.uid);

      // CORREÇÃO: list simplificado — personal pode listar seus próprios alunos.
      // A segurança real vem do where('personalId', '==', uid) que o código sempre usa.
      // Qualquer query que não filtre pelo próprio uid será negada abaixo pois
      // os documentos retornados terão personalId != request.auth.uid e o get falhará.
      allow list: if isAuth() && isPersonal() && (
        // query: where('personalId', '==', uid) — filtro pode estar em qualquer posição
        request.query.filters.size() >= 1 && (
          (request.query.filters[0].field_path == 'personalId' &&
           request.query.filters[0].value == request.auth.uid)
          ||
          (request.query.filters.size() >= 2 &&
           request.query.filters[1].field_path == 'personalId' &&
           request.query.filters[1].value == request.auth.uid)
        )
      );

      // Criação pelo próprio usuário (personal cadastrando a si mesmo)
      allow create: if isUser(userId);

      // Personal criando conta de aluno
      allow create: if isPersonal()
        && request.resource.data.userType == 'student'
        && request.resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid)
        && isWithinStudentLimit(request.auth.uid);

      // Aluno ativando sua própria conta
      allow create: if isAuth()
        && request.resource.data.userType == 'student'
        && request.resource.data.authUid == request.auth.uid;

      // Aluno editando só campos seguros do próprio perfil
      allow update: if isUser(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['assignedWorkouts', 'personalId', 'userType', 'authUid', 'uid', 'email']);

      // Personal editando dados do próprio aluno
      allow update: if isMyStudentDoc() || isOwnStudentDoc();

      // Deleção
      allow delete: if isUser(userId)
        || isMyStudentDoc()
        || isOwnStudentDoc()
        || (isAuth()
            && resource.data.userType == 'student'
            && (resource.data.status == 'pending' || resource.data.status == 'activating'));
    }

    // ── EXERCISES ──────────────────────────────────────────────────────────
    match /exercises/{exerciseId} {
      allow read: if isAuth() && (
        resource.data.personalId == request.auth.uid
        || (
          getUserData().userType == 'student'
          && getUserData().personalId == resource.data.personalId
        )
      );

      allow list: if isAuth() && (
        // Personal listando seus exercícios
        (isPersonal() &&
         request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'personalId' &&
         request.query.filters[0].value == request.auth.uid)
        ||
        // Aluno listando exercícios do seu personal
        (getUserData().userType == 'student' &&
         request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'personalId' &&
         request.query.filters[0].value == getUserData().personalId)
      );

      allow create: if isAuth() && isPersonal()
        && request.resource.data.personalId == request.auth.uid
        && request.resource.data.name.size() <= 200
        && (!('description' in request.resource.data) || request.resource.data.description.size() <= 2000)
        && hasActiveSubscription(request.auth.uid);

      allow update: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow delete: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid;
    }

    // ── WORKOUTS ───────────────────────────────────────────────────────────
    match /workouts/{workoutId} {
      allow get: if isAuth() && (
        resource.data.personalId == request.auth.uid ||
        (resource.data.studentId == request.auth.uid &&
          hasActiveSubscription(resource.data.personalId))
      );

      allow list: if isAuth() && (
        // Personal listando seus treinos
        (request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'personalId' &&
         request.query.filters[0].value == request.auth.uid)
        ||
        // Aluno listando seus treinos (com assinatura ativa do personal)
        (request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'studentId' &&
         request.query.filters[0].value == request.auth.uid &&
         getUserData().userType == 'student' &&
         hasActiveSubscription(getUserData().personalId))
      );

      allow create: if isAuth() && isPersonal()
        && request.resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow update: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow delete: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid;
    }

    // ── FEEDBACKS ──────────────────────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      // Aluno criando feedback com validação completa dos campos
      allow create: if isAuth()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.effortLevel is int
        && request.resource.data.effortLevel >= 1
        && request.resource.data.effortLevel <= 10
        && request.resource.data.dayOfWeek in [
             'monday','tuesday','wednesday','thursday',
             'friday','saturday','sunday']
        && request.resource.data.sensation in ['leve','ideal','pesado']
        && request.resource.data.weekIdentifier.matches('^[0-9]{4}-[0-9]{1,2}$')
        && request.resource.data.hasPain is bool
        && request.resource.data.comment.size() <= 1000
        && exists(/databases/$(database)/documents/workouts/$(request.resource.data.workoutId))
        && get(/databases/$(database)/documents/workouts/$(request.resource.data.workoutId)).data.studentId
           == request.auth.uid;

      // Aluno lendo/editando seus próprios feedbacks
      allow get, update: if isAuth()
        && resource.data.studentId == request.auth.uid;

      // Personal lendo/deletando feedbacks dos seus treinos
      allow get, delete: if isAuth() && isPersonal() && (
        exists(/databases/$(database)/documents/workouts/$(resource.data.workoutId)) &&
        get(/databases/$(database)/documents/workouts/$(resource.data.workoutId)).data.personalId
          == request.auth.uid
      );

      // CORREÇÃO: list de feedbacks — três casos permitidos
      allow list: if isAuth() && (
        // 1. Aluno listando seus próprios feedbacks
        (request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'studentId' &&
         request.query.filters[0].value == request.auth.uid)
        ||
        // 2. Personal listando feedbacks diretamente pelo personalId (campo desnormalizado)
        (isPersonal() &&
         request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'personalId' &&
         request.query.filters[0].value == request.auth.uid)
        ||
        // 3. Personal listando feedbacks por workoutId (fallback chunk query)
        (isPersonal() &&
         request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'workoutId')
      );
    }

    // ── SUBSCRIPTIONS ──────────────────────────────────────────────────────
    match /subscriptions/{personalId} {
      allow read:  if isUser(personalId);
      allow write: if false;
    }

    // ── BILLINGS ───────────────────────────────────────────────────────────
    match /billings/{billingId} {
      allow read:  if isAuth() && resource.data.personalId == request.auth.uid;
      allow write: if false;
    }

    // ── NOTIFICATIONS ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow write: if false;
    }

    // ── BACKEND ONLY ────────────────────────────────────────────────────────
    match /processedWebhooks/{id} { allow read, write: if false; }
    match /securityLogs/{id}      { allow read, write: if false; }
    match /activationLocks/{id}   { allow read, write: if false; }
    match /cronLocks/{id}         { allow read, write: if false; }

    // ── PENDING ACTIVATIONS ─────────────────────────────────────────────────
    match /pendingActivations/{emailKey} {
      allow get: if isAuth() && isPersonal()
        && resource.data.createdBy == request.auth.uid;

      allow list: if false;

      allow create: if isAuth() && isPersonal()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.studentDocId is string
        && request.resource.data.studentDocId.size() > 0
        && request.resource.data.activationToken is string
        && request.resource.data.activationToken.size() == 64
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt < request.time + duration.value(8, 'd');

      allow update: if isAuth() && isPersonal()
        && resource.data.createdBy == request.auth.uid;

      allow delete: if isAuth() && isPersonal()
        && resource.data.createdBy == request.auth.uid;
    }

    // ── DEFAULT BLOCK ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
