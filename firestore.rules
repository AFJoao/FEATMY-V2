rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPersonal() {
      return isAuth() && getUserData().userType == 'personal';
    }

    function hasActiveSubscription(personalId) {
      return exists(/databases/$(database)/documents/subscriptions/$(personalId)) &&
        get(/databases/$(database)/documents/subscriptions/$(personalId)).data.status
          in ['active', 'grace_period'];
    }

    function isWithinStudentLimit(personalId) {
      let subDoc      = get(/databases/$(database)/documents/subscriptions/$(personalId));
      let maxStudents = subDoc.data.maxStudents;
      let userDoc     = get(/databases/$(database)/documents/users/$(personalId));
      let currentCount = ('students' in userDoc.data && userDoc.data.students != null)
        ? userDoc.data.students.size()
        : 0;
      return exists(/databases/$(database)/documents/subscriptions/$(personalId)) &&
        currentCount < maxStudents;
    }

    function isOwnStudentDoc() {
      return isAuth()
        && resource.data.userType == 'student'
        && resource.data.authUid == request.auth.uid;
    }

    function isMyStudentDoc() {
      return isPersonal() && resource.data.personalId == request.auth.uid;
    }

    // ── USERS ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isUser(userId)
        || (resource.data.status == 'pending' && resource.data.userType == 'student'
            && isAuth() && resource.data.personalId == request.auth.uid)
        || (isAuth() && resource.data.personalId == request.auth.uid);

      // CORRIGIDO VULN 2: list força filtro por personalId do próprio usuário autenticado.
      // Personal só lista seus próprios alunos; listagem geral de users é proibida.
      allow list: if isAuth() && isPersonal() && (
        request.query.filters.size() >= 1 &&
        (
          (request.query.filters[0].field_path == 'personalId' &&
           request.query.filters[0].value == request.auth.uid)
          ||
          (request.query.filters.size() >= 2 &&
           request.query.filters[1].field_path == 'personalId' &&
           request.query.filters[1].value == request.auth.uid)
        )
      );

      allow create: if isUser(userId);

      allow create: if isPersonal()
        && request.resource.data.userType == 'student'
        && request.resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid)
        && isWithinStudentLimit(request.auth.uid);

      allow create: if isAuth()
        && request.resource.data.userType == 'student'
        && request.resource.data.authUid == request.auth.uid;

      allow update: if isUser(userId) || isMyStudentDoc() || isOwnStudentDoc();

      allow delete: if isUser(userId)
        || isMyStudentDoc()
        || isOwnStudentDoc()
        || (isAuth()
            && resource.data.userType == 'student'
            && (resource.data.status == 'pending' || resource.data.status == 'activating'));
    }

    // ── EXERCISES ──────────────────────────────────────────────────
    match /exercises/{exerciseId} {
      allow read: if isAuth() && (
        resource.data.personalId == request.auth.uid
        || (
          getUserData().userType == 'student'
          && getUserData().personalId == resource.data.personalId
        )
      );

      allow create: if isAuth() && isPersonal()
        && request.resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow update: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow delete: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid;
    }

    // ── WORKOUTS ───────────────────────────────────────────────────
    match /workouts/{workoutId} {
      allow get: if isAuth() && (
        resource.data.personalId == request.auth.uid ||
        (resource.data.studentId == request.auth.uid &&
          hasActiveSubscription(resource.data.personalId))
      );

      // CORRIGIDO VULN 1: list exige filtro por personalId ou studentId do próprio usuário.
      // Firestore Security Rules não expõem resource.data em list — a proteção é via
      // filtro obrigatório na query. O cliente DEVE filtrar por seu próprio UID.
      allow list: if isAuth() && (
        // Personal lista seus próprios treinos
        (request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'personalId' &&
         request.query.filters[0].value == request.auth.uid)
        ||
        // Aluno lista treinos atribuídos a ele
        (request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'studentId' &&
         request.query.filters[0].value == request.auth.uid)
      );

      allow create: if isAuth() && isPersonal()
        && request.resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow update: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid
        && hasActiveSubscription(request.auth.uid);

      allow delete: if isAuth() && isPersonal()
        && resource.data.personalId == request.auth.uid;
    }

    // ── FEEDBACKS ──────────────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      allow create: if isAuth()
        && request.resource.data.studentId == request.auth.uid;

      allow get, update: if isAuth()
        && resource.data.studentId == request.auth.uid;

      allow get, delete: if isAuth() && isPersonal() && (
        exists(/databases/$(database)/documents/workouts/$(resource.data.workoutId)) &&
        get(/databases/$(database)/documents/workouts/$(resource.data.workoutId)).data.personalId
          == request.auth.uid
      );

      // CORRIGIDO: list de feedbacks requer filtro por studentId ou personalId do próprio usuário
      allow list: if isAuth() && (
        // Aluno vê seus próprios feedbacks
        (request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'studentId' &&
         request.query.filters[0].value == request.auth.uid)
        ||
        // Personal via workoutId (in query) — permitido pois workouts são seus
        (isPersonal() && request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'workoutId')
        ||
        // Personal via personalId desnormalizado
        (isPersonal() && request.query.filters.size() >= 1 &&
         request.query.filters[0].field_path == 'personalId' &&
         request.query.filters[0].value == request.auth.uid)
      );
    }

    // ── SUBSCRIPTIONS ──────────────────────────────────────────────
    match /subscriptions/{personalId} {
      allow read:  if isUser(personalId);
      allow write: if false;
    }

    // ── BILLINGS ───────────────────────────────────────────────────
    match /billings/{billingId} {
      allow read:  if isAuth() && resource.data.personalId == request.auth.uid;
      allow write: if false;
    }

    // ── NOTIFICATIONS ───────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow write: if false;
    }

    // ── BACKEND ONLY ────────────────────────────────────────────────
    match /processedWebhooks/{id} { allow read, write: if false; }
    match /securityLogs/{id}      { allow read, write: if false; }

    // ── PENDING ACTIVATIONS ─────────────────────────────────────────
    match /pendingActivations/{emailKey} {
      allow get: if isAuth() && isPersonal()
        && resource.data.createdBy == request.auth.uid;

      allow list: if false;

      allow create: if isAuth() && isPersonal()
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuth() && isPersonal()
        && resource.data.createdBy == request.auth.uid;

      allow delete: if isAuth() && isPersonal()
        && resource.data.createdBy == request.auth.uid;
    }

    // ── ACTIVATION LOCKS (backend only) ────────────────────────────
    match /activationLocks/{lockId} { allow read, write: if false; }

    // ── DEFAULT BLOCK ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
